QMainWindow {
    background-color: #F7FAFC;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 14pt;
}

QPushButton {
    background-color: #2C5282;
    color: #FFFFFF;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2B6CB0;
}

QGroupBox {
    font-weight: bold;
    border: 2px solid #E2E8F0;
    border-radius: 8px;
    margin-top: 1ex;
    padding-top: 8px;
}


